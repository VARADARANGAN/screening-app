# Database Configuration (PostgreSQL - Ready for Supabase)
DATABASE_URL=postgresql://user:password@localhost:5432/aptitude_portal
DB_HOST=localhost
DB_PORT=5432
DB_NAME=aptitude_portal
DB_USER=postgres
DB_PASSWORD=your_password

# Supabase
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Authentication
JWT_SECRET=your-super-secret-key-change-in-production-min-32-chars
JWT_EXPIRE=7d
BCRYPT_ROUNDS=10

# External APIs
PISTON_API_URL=https://emkc.org/api/v2/piston
# Piston API does not require an API key for the public endpoint

# Application
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# File Upload
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=application/vnd.ms-excel,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet,text/csv

# Email Configuration (for future use)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
